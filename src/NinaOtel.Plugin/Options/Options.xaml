<ResourceDictionary
    x:Class="NinaOtel.Plugin.Options.Options"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <BooleanToVisibilityConverter x:Key="NinaOtel_BooleanToVisibilityConverter" />

    <DataTemplate x:Key="NinaOtel_Options">
        <StackPanel Orientation="Vertical" Margin="8">
            <TextBlock Text="NinaOtel" FontWeight="Bold" FontSize="16" />
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
                <Ellipse
                    Width="10"
                    Height="10"
                    Fill="{Binding NinaOtelOptionsViewModel.CollectorHealthBrush}"
                    Margin="0,0,6,0"
                    VerticalAlignment="Center" />
                <TextBlock
                    Text="{Binding NinaOtelOptionsViewModel.CollectorHealthSummary}"
                    VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock
                Text="{Binding NinaOtelOptionsViewModel.CollectorHealthDebugInfo}"
                Margin="16,2,0,0"
                Foreground="#666666"
                FontSize="11"
                TextWrapping="Wrap" />
            <TextBlock Text="{Binding NinaOtelOptionsViewModel.Status}" Margin="0,8,0,0" />
            <TextBlock Text="Add-ons" FontWeight="Bold" Margin="0,12,0,0" />
            <ItemsControl ItemsSource="{Binding NinaOtelOptionsViewModel.Addons}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="4" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="4" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="4" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="4" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="4" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="4" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="4" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="4" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="4" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="4" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding DisplayName}" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding Source}" Foreground="#666666" />

                            <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    Text="Enabled:"
                                    VerticalAlignment="Center"
                                    Margin="0,0,6,0" />
                                <CheckBox
                                    Grid.Column="1"
                                    IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                    ToolTip="Enable this add-on telemetry." />
                                <TextBlock
                                    Grid.Column="3"
                                    Text="Raw log forwarding:"
                                    VerticalAlignment="Center"
                                    Margin="0,0,6,0" />
                                <CheckBox
                                    Grid.Column="4"
                                    IsChecked="{Binding RawForwardingEnabled, Mode=TwoWay}"
                                    ToolTip="Forward raw source log lines in addition to parsed telemetry." />
                            </Grid>

                            <TextBlock
                                Grid.Row="4"
                                Grid.Column="0"
                                Text="PHD2 debug log:"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsPhd2, Converter={StaticResource NinaOtel_BooleanToVisibilityConverter}}" />
                            <TextBox
                                Grid.Row="4"
                                Grid.Column="2"
                                MinWidth="220"
                                Text="{Binding Phd2DebugLogPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                Visibility="{Binding IsPhd2, Converter={StaticResource NinaOtel_BooleanToVisibilityConverter}}" />

                            <TextBlock
                                Grid.Row="6"
                                Grid.Column="0"
                                Text="PHD2 guide log:"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsPhd2, Converter={StaticResource NinaOtel_BooleanToVisibilityConverter}}" />
                            <TextBox
                                Grid.Row="6"
                                Grid.Column="2"
                                MinWidth="220"
                                Text="{Binding Phd2GuideLogPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                Visibility="{Binding IsPhd2, Converter={StaticResource NinaOtel_BooleanToVisibilityConverter}}" />

                            <TextBlock
                                Grid.Row="8"
                                Grid.Column="0"
                                Text="Target Scheduler log:"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsTargetScheduler, Converter={StaticResource NinaOtel_BooleanToVisibilityConverter}}" />
                            <TextBox
                                Grid.Row="8"
                                Grid.Column="2"
                                MinWidth="220"
                                Text="{Binding TargetSchedulerLogPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                Visibility="{Binding IsTargetScheduler, Converter={StaticResource NinaOtel_BooleanToVisibilityConverter}}" />

                            <TextBlock
                                Grid.Row="10"
                                Grid.Column="0"
                                Text="Night Summary log:"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsNightSummary, Converter={StaticResource NinaOtel_BooleanToVisibilityConverter}}" />
                            <TextBox
                                Grid.Row="10"
                                Grid.Column="2"
                                MinWidth="220"
                                Text="{Binding NightSummaryLogPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                Visibility="{Binding IsNightSummary, Converter={StaticResource NinaOtel_BooleanToVisibilityConverter}}" />

                            <TextBlock
                                Grid.Row="12"
                                Grid.Column="0"
                                Text="OnStepX host:"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsOnStepX, Converter={StaticResource NinaOtel_BooleanToVisibilityConverter}}" />
                            <TextBox
                                Grid.Row="12"
                                Grid.Column="2"
                                MinWidth="220"
                                Text="{Binding OnStepXHost, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                Visibility="{Binding IsOnStepX, Converter={StaticResource NinaOtel_BooleanToVisibilityConverter}}" />

                            <TextBlock
                                Grid.Row="14"
                                Grid.Column="0"
                                Text="OnStepX port:"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsOnStepX, Converter={StaticResource NinaOtel_BooleanToVisibilityConverter}}" />
                            <TextBox
                                Grid.Row="14"
                                Grid.Column="2"
                                Width="120"
                                HorizontalAlignment="Left"
                                Text="{Binding OnStepXPort, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                Visibility="{Binding IsOnStepX, Converter={StaticResource NinaOtel_BooleanToVisibilityConverter}}" />

                            <TextBlock
                                Grid.Row="16"
                                Grid.Column="0"
                                Text="Poll seconds:"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsOnStepX, Converter={StaticResource NinaOtel_BooleanToVisibilityConverter}}" />
                            <TextBox
                                Grid.Row="16"
                                Grid.Column="2"
                                Width="120"
                                HorizontalAlignment="Left"
                                Text="{Binding OnStepXPollingIntervalSeconds, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                Visibility="{Binding IsOnStepX, Converter={StaticResource NinaOtel_BooleanToVisibilityConverter}}" />

                            <TextBlock
                                Grid.Row="18"
                                Grid.Column="0"
                                Text="Timeout ms:"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsOnStepX, Converter={StaticResource NinaOtel_BooleanToVisibilityConverter}}" />
                            <TextBox
                                Grid.Row="18"
                                Grid.Column="2"
                                Width="120"
                                HorizontalAlignment="Left"
                                Text="{Binding OnStepXCommandTimeoutMilliseconds, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                Visibility="{Binding IsOnStepX, Converter={StaticResource NinaOtel_BooleanToVisibilityConverter}}" />

                            <TextBlock Grid.Row="20" Grid.Column="0" Text="{Binding Status}" Foreground="#666666" />
                            <TextBlock
                                Grid.Row="20"
                                Grid.Column="2"
                                Text="{Binding Message}"
                                Foreground="#666666"
                                TextWrapping="Wrap" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Collector:" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBox
                    Grid.Row="0"
                    Grid.Column="2"
                    MinWidth="320"
                    Text="{Binding NinaOtelOptionsViewModel.CollectorEndpoint, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Protocol:" FontWeight="SemiBold" VerticalAlignment="Center" />
                <ComboBox
                    Grid.Row="2"
                    Grid.Column="2"
                    Width="160"
                    HorizontalAlignment="Left"
                    ItemsSource="{Binding NinaOtelOptionsViewModel.AvailableProtocols}"
                    SelectedItem="{Binding NinaOtelOptionsViewModel.CollectorProtocol, Mode=TwoWay}" />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Static headers:" FontWeight="SemiBold" VerticalAlignment="Top" />
                <TextBox
                    Grid.Row="4"
                    Grid.Column="2"
                    MinWidth="320"
                    MinHeight="56"
                    AcceptsReturn="True"
                    TextWrapping="NoWrap"
                    VerticalScrollBarVisibility="Auto"
                    Text="{Binding NinaOtelOptionsViewModel.StaticHeaders, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Authentication:" FontWeight="SemiBold" VerticalAlignment="Center" />
                <ComboBox
                    Grid.Row="6"
                    Grid.Column="2"
                    Width="160"
                    HorizontalAlignment="Left"
                    ItemsSource="{Binding NinaOtelOptionsViewModel.AvailableAuthenticationModes}"
                    SelectedItem="{Binding NinaOtelOptionsViewModel.AuthenticationMode, Mode=TwoWay}" />

                <TextBlock Grid.Row="8" Grid.Column="0" Text="Bearer token:" FontWeight="SemiBold" VerticalAlignment="Center" />
                <PasswordBox
                    Grid.Row="8"
                    Grid.Column="2"
                    MinWidth="320"
                    Loaded="BearerTokenPasswordBox_Loaded"
                    LostFocus="BearerTokenPasswordBox_LostFocus"
                    PasswordChanged="BearerTokenPasswordBox_PasswordChanged"
                    Unloaded="SecretPasswordBox_Unloaded" />

                <TextBlock Grid.Row="10" Grid.Column="0" Text="Basic username:" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBox
                    Grid.Row="10"
                    Grid.Column="2"
                    MinWidth="320"
                    Text="{Binding NinaOtelOptionsViewModel.BasicUsername, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                <TextBlock Grid.Row="12" Grid.Column="0" Text="Basic password:" FontWeight="SemiBold" VerticalAlignment="Center" />
                <PasswordBox
                    Grid.Row="12"
                    Grid.Column="2"
                    MinWidth="320"
                    Loaded="BasicPasswordBox_Loaded"
                    LostFocus="BasicPasswordBox_LostFocus"
                    PasswordChanged="BasicPasswordBox_PasswordChanged"
                    Unloaded="SecretPasswordBox_Unloaded" />

                <TextBlock Grid.Row="14" Grid.Column="0" Text="CA PEM:" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBox
                    Grid.Row="14"
                    Grid.Column="2"
                    MinWidth="320"
                    Text="{Binding NinaOtelOptionsViewModel.CaCertificatePemPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                <TextBlock Grid.Row="16" Grid.Column="0" Text="Client cert PEM:" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBox
                    Grid.Row="16"
                    Grid.Column="2"
                    MinWidth="320"
                    Text="{Binding NinaOtelOptionsViewModel.ClientCertificatePemPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                <TextBlock Grid.Row="18" Grid.Column="0" Text="Client key PEM:" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBox
                    Grid.Row="18"
                    Grid.Column="2"
                    MinWidth="320"
                    Text="{Binding NinaOtelOptionsViewModel.ClientPrivateKeyPemPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
            </Grid>
            <CheckBox
                Content="Disk spool on collector failure"
                IsChecked="{Binding NinaOtelOptionsViewModel.DiskOnFailureEnabled, Mode=TwoWay}"
                Margin="0,8,0,0" />
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Spool path:" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBox
                    Grid.Row="0"
                    Grid.Column="2"
                    MinWidth="320"
                    Text="{Binding NinaOtelOptionsViewModel.SpoolPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Max spool GB:" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBox
                    Grid.Row="2"
                    Grid.Column="2"
                    Width="120"
                    HorizontalAlignment="Left"
                    Text="{Binding NinaOtelOptionsViewModel.MaxSpoolSizeGb, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Max spool days:" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBox
                    Grid.Row="4"
                    Grid.Column="2"
                    Width="120"
                    HorizontalAlignment="Left"
                    Text="{Binding NinaOtelOptionsViewModel.MaxSpoolAgeDays, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
            </Grid>
        </StackPanel>
    </DataTemplate>
</ResourceDictionary>
