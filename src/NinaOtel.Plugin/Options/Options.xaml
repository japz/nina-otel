<ResourceDictionary
    x:Class="NinaOtel.Plugin.Options.Options"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DataTemplate x:Key="NinaOtel_Options">
        <StackPanel Orientation="Vertical" Margin="8">
            <TextBlock Text="NinaOtel" FontWeight="Bold" FontSize="16" />
            <TextBlock Text="{Binding NinaOtelOptionsViewModel.Status}" Margin="0,8,0,0" />
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Collector:" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBox
                    Grid.Row="0"
                    Grid.Column="2"
                    MinWidth="320"
                    Text="{Binding NinaOtelOptionsViewModel.CollectorEndpoint, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Protocol:" FontWeight="SemiBold" VerticalAlignment="Center" />
                <ComboBox
                    Grid.Row="2"
                    Grid.Column="2"
                    Width="160"
                    HorizontalAlignment="Left"
                    ItemsSource="{Binding NinaOtelOptionsViewModel.AvailableProtocols}"
                    SelectedItem="{Binding NinaOtelOptionsViewModel.CollectorProtocol, Mode=TwoWay}" />
            </Grid>
            <CheckBox
                Content="Disk spool on collector failure"
                IsChecked="{Binding NinaOtelOptionsViewModel.DiskOnFailureEnabled, Mode=TwoWay}"
                Margin="0,8,0,0" />
        </StackPanel>
    </DataTemplate>
</ResourceDictionary>
